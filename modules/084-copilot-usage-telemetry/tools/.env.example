# Copilot Usage Telemetry — credentials template
# Copy this file to a `.env` (next to the script OR at the repo root) and fill in your value.
# The real `.env` is gitignored — never commit it.

# GitHub token used to query the private Copilot quota/credits endpoint.
# How to obtain it: see the module walkthrough. A classic GitHub Personal Access
# Token (PAT) tied to a Copilot-enabled account is the starting point.
COPILOT_GITHUB_TOKEN=ghp_your_token_here

# Optional: override the GitHub API base (defaults to https://api.github.com)
# COPILOT_API_BASE=https://api.github.com
