# Jira CLI — credentials template
# Copy this file to work/470-task/.env and fill in your values.
# Never commit the .env file — it is in .gitignore.

# --- Atlassian Cloud (basic auth) ---
# JIRA_URL=https://your-org.atlassian.net
# JIRA_EMAIL=your.email@company.com
# JIRA_API_TOKEN=your_cloud_api_token_here
# JIRA_AUTH_TYPE=basic

# --- Jira Server / Data Center (Personal Access Token / bearer auth) ---
# Generate PAT in Jira: Profile → Personal Access Tokens → Create token
JIRA_URL=https://your-jira.company.com
JIRA_EMAIL=your.username@company.com
JIRA_API_TOKEN=your_personal_access_token_here
JIRA_AUTH_TYPE=bearer
# JIRA_API_VERSION=2   # optional, defaults to 2 for bearer, 3 for basic
