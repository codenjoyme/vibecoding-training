# =============================================================================
# Teams AI Assistant — local secrets (TEMPLATE)
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# =============================================================================

# --- Microsoft Entra ID (Azure AD) App Registration --------------------------
# Source: portal.azure.com → Entra ID → App registrations → <your app> → Overview
## Directory (tenant) ID field 
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
## Application (client) ID field
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Source: <your app> → Certificates & secrets → Client secrets → Value
# (shown only once at creation; if lost — delete and create a new one)
AZURE_CLIENT_SECRET=replace-with-client-secret-value

# Optional: redirect URI registered for the public client.
# Must match the value set in the App Registration (default in our setup).
AZURE_REDIRECT_URI=http://localhost

# Optional: Microsoft Graph scopes the app will request at sign-in.
# Keep aligned with the API permissions added in the portal.
GRAPH_SCOPES=Chat.Read ChatMessage.Read Chat.ReadWrite ChatMessage.Send offline_access

# Source: run `python create_notification_chat.py` once and paste the printed id.
# This is the dedicated chat where AI summaries will be posted.
NOTIFICATION_CHAT_ID=19:replace-with-chat-id@thread.v2

# --- LLM backend (GitHub Models) ---------------------------------------------
# Source: github.com → Settings → Developer settings → Personal access tokens
# Needs access to GitHub Models. Free tier is enough for PoC usage.
GITHUB_TOKEN=ghp_replace_with_personal_access_token

# Optional: which model to use via the GitHub Models endpoint.
LLM_MODEL=gpt-4o
LLM_ENDPOINT=https://models.inference.ai.azure.com

# --- App runtime tuning (safe defaults; can stay as-is) ----------------------
# How many of the most recent chats to scan on startup.
INITIAL_CHAT_LIMIT=50

# How many last messages per chat to summarize on first pass.
INITIAL_MESSAGES_PER_CHAT=40

# Polling interval for new messages, in minutes.
POLL_INTERVAL_MINUTES=5

# How many incremental updates before forcing a full re-summary of a chat.
RESUMMARIZE_EVERY_N_UPDATES=10
